@model ProductUI.Models.Product

<h2>Edit Product</h2>

<form method="post">
    <input type="hidden" asp-for="Id" />

    Name: <input asp-for="Name" /><br />
    Price: <input asp-for="Price" /><br />
    Category: <input asp-for="Category" /><br />

    <button type="submit">Update</button>
</form>